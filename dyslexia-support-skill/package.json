{
  "name": "dyslexia-support-skill",
  "version": "1.0.0",
  "description": "Accessibility tools for reading support, text simplification, and font recommendations tailored to dyslexic users",
  "author": "Justice",
  "license": "MIT",
  "type": "module",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": {
    "dyslexia-support": "dist/cli/cli.js"
  },
  "files": [
    "dist/",
    "source/",
    "skills/",
    "commands/",
    ".claude-plugin/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/justice8096/accessibility-skills.git",
    "directory": "dyslexia-support-skill"
  },
  "homepage": "https://github.com/justice8096/accessibility-skills/tree/main/dyslexia-support-skill",
  "bugs": {
    "url": "https://github.com/justice8096/accessibility-skills/issues"
  },
  "keywords": [
    "dyslexia",
    "accessibility",
    "reading",
    "text-simplification",
    "a11y",
    "i18n",
    "claude-plugin",
    "openai",
    "n8n",
    "mcp"
  ],
  "scripts": {
    "build": "tsx build.ts",
    "build:claude": "tsx build.ts --format claude-plugin",
    "build:openai": "tsx build.ts --format openai",
    "build:n8n": "tsx build.ts --format n8n",
    "build:mcp": "tsx build.ts --format mcp",
    "build:prompts": "tsx build.ts --format prompts",
    "build:cli": "tsx build.ts --format cli",
    "build:locale": "tsx build.ts --locale",
    "build:watch": "tsx --watch build.ts",
    "compile": "tsc -p tsconfig.publish.json",
    "prepublishOnly": "npm run build && npm run compile",
    "clean": "rm -rf dist",
    "validate": "tsx build.ts --validate-only",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "typescript": "5.9.3",
    "tsx": "4.21.0",
    "zod": "3.25.76"
  }
}
